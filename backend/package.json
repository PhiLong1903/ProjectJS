{
  "name": "hospital-ehealth-backend",
  "version": "1.0.0",
  "description": "Backend REST API cho website benh vien da khoa tich hop E-Health Booking",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --watch src --ext js,mjs,cjs,json --exec \"node src/server.js\"",
    "build": "echo \"JavaScript source - no build step\"",
    "start": "node src/server.js",
    "lint": "echo \"No lint configured yet for JavaScript backend\"",
    "typecheck": "echo \"TypeScript typecheck disabled (project uses JavaScript)\"",
    "test": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "db:migrate": "node scripts/db-runner.js migrate",
    "db:seed": "node scripts/db-runner.js seed",
    "db:seed:demo": "node scripts/db-runner.js seed:demo",
    "db:init": "node scripts/db-runner.js init",
    "db:init:demo": "node scripts/db-runner.js init:demo"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.16.3",
    "redis": "^5.11.0",
    "sequelize": "^6.37.8",
    "slugify": "^1.6.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  }
}
