NODE_ENV=development
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital_ehealth

JWT_ACCESS_SECRET=your-very-long-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=your-very-long-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN_DAYS=14
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=15
PASSWORD_RESET_URL=http://localhost:5173/reset-password

LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10
LAB_LOOKUP_RATE_LIMIT_WINDOW_MS=60000
LAB_LOOKUP_RATE_LIMIT_MAX=20

# Redis (rate limit)
REDIS_RATE_LIMIT_ENABLED=false
REDIS_URL=redis://localhost:6379

NOTIFICATION_QUEUE_ENABLED=true
NOTIFICATION_QUEUE_POLL_MS=10000
NOTIFICATION_QUEUE_BATCH_SIZE=20

CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
COOKIE_SECURE=false
